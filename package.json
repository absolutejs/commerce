{
  "name": "@absolutejs/commerce",
  "version": "0.38.0-beta.0",
  "description": "Provider-agnostic commerce primitives (cart, orders, fulfillment, shipping) for AbsoluteJS",
  "repository": {
    "type": "git",
    "url": "https://github.com/absolutejs/commerce.git"
  },
  "homepage": "https://github.com/absolutejs/commerce",
  "bugs": {
    "url": "https://github.com/absolutejs/commerce/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "browser": "./dist/client/index.js",
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./react": {
      "browser": "./dist/react/index.js",
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./decoration-react": {
      "browser": "./dist/decoration-react/index.js",
      "import": "./dist/decoration-react/index.js",
      "types": "./dist/decoration-react/index.d.ts"
    },
    "./drizzle": {
      "import": "./dist/drizzle/index.js",
      "types": "./dist/drizzle/index.d.ts",
      "default": "./dist/drizzle/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./manifest.json": "./dist/manifest.json"
  },
  "license": "BSL-1.1",
  "author": "Alex Kahn",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/drizzle/index.ts ./src/react/index.tsx ./src/manifest.ts --root ./src --outdir dist --target bun --external drizzle-orm --external react --external fflate && bun build ./src/client/index.ts --outdir dist/client --target browser --format esm && bun build ./src/decoration-react/index.ts --outdir dist/decoration-react --target browser --format esm --external react --external three --external '@react-three/*' && tsc --emitDeclarationOnly --project tsconfig.json && absolute-manifest emit",
    "format": "prettier --write \"./**/*.{js,ts,json,md}\"",
    "release": "bun run build && bun publish --tag beta",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "drizzle-orm": ">=1.0.0-rc.4",
    "react": ">=18.0.0",
    "three": "",
    "@react-three/drei": ">=9.0.0",
    "@react-three/fiber": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "@react-three/drei": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/bun": "1.3.9",
    "@types/react": "^19.0.0",
    "@types/three": "^0.185.0",
    "drizzle-orm": "1.0.0-rc.4",
    "prettier": "^3.9.6",
    "react": "^19.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@absolutejs/manifest": "^0.1.0",
    "@sinclair/typebox": "^0.34.0",
    "fflate": "^0.8.3"
  },
  "absolutejs": {
    "manifestContract": 1
  }
}
